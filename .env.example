# ============================================
# AI-KnowledgeHub 环境变量示例文件
# 复制为 .env 后按需修改
# ============================================

# MySQL
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=ai_knowledgehub
MYSQL_USER=akh
MYSQL_PASSWORD=akh123456
MYSQL_PORT=3306

# Redis（如需密码，设置 REDIS_PASSWORD）
REDIS_PASSWORD=
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# JWT（生产环境务必修改，且长度 >= 32 字节）
JWT_SECRET=ai-knowledgehub-default-secret-key-for-jwt-token-generation-2024-do-not-use-in-prod
JWT_EXPIRATION=86400000
