{
  "info": {
    "name": "AI-KnowledgeHub API",
    "description": "基于 AI 的智能知识库与内容发布平台 API 测试集",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "rankingUrl",
      "value": "http://localhost:8083",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "articleId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "文章管理",
      "item": [
        {
          "name": "创建文章草稿",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Redis ZSET 实现热榜\",\n  \"content\": \"Redis ZSET 是一个有序集合，非常适合实现排行榜功能...\",\n  \"summary\": \"本文介绍如何使用 Redis ZSET 实现实时热榜\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/articles/draft",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "draft"]
            }
          },
          "response": []
        },
        {
          "name": "修改文章",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Redis ZSET 实现热榜（更新版）\",\n  \"content\": \"Redis ZSET 是一个有序集合，非常适合实现排行榜功能。本文详细介绍...\",\n  \"summary\": \"本文深入介绍如何使用 Redis ZSET 实现实时热榜\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/articles/{{articleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "{{articleId}}"]
            }
          },
          "response": []
        },
        {
          "name": "发布文章",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/articles/{{articleId}}/publish",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "{{articleId}}", "publish"]
            }
          },
          "response": []
        },
        {
          "name": "删除文章（逻辑删除）",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/articles/{{articleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "{{articleId}}"]
            }
          },
          "response": []
        },
        {
          "name": "获取最新文章列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/articles/latest?page=1&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "latest"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "获取文章详情",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/articles/{{articleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "{{articleId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "评论功能",
      "item": [
        {
          "name": "发表评论",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"这篇文章写得很好，学到了很多！\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/articles/{{articleId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "{{articleId}}", "comments"]
            }
          },
          "response": []
        },
        {
          "name": "获取评论列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/articles/{{articleId}}/comments?page=1&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "{{articleId}}", "comments"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "点赞功能",
      "item": [
        {
          "name": "点赞文章",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/articles/{{articleId}}/like",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "{{articleId}}", "like"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "热榜功能",
      "item": [
        {
          "name": "获取热榜 Top10",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{rankingUrl}}/api/ranking/top10",
              "host": ["{{rankingUrl}}"],
              "path": ["api", "ranking", "top10"]
            }
          },
          "response": []
        },
        {
          "name": "阅读热度+1",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{rankingUrl}}/api/ranking/articles/{{articleId}}/view",
              "host": ["{{rankingUrl}}"],
              "path": ["api", "ranking", "articles", "{{articleId}}", "view"]
            }
          },
          "response": []
        },
        {
          "name": "点赞热度+5",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{rankingUrl}}/api/ranking/articles/{{articleId}}/like",
              "host": ["{{rankingUrl}}"],
              "path": ["api", "ranking", "articles", "{{articleId}}", "like"]
            }
          },
          "response": []
        },
        {
          "name": "评论热度+3",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{rankingUrl}}/api/ranking/articles/{{articleId}}/comment",
              "host": ["{{rankingUrl}}"],
              "path": ["api", "ranking", "articles", "{{articleId}}", "comment"]
            }
          },
          "response": []
        },
        {
          "name": "发布热度+2",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{rankingUrl}}/api/ranking/articles/{{articleId}}/publish",
              "host": ["{{rankingUrl}}"],
              "path": ["api", "ranking", "articles", "{{articleId}}", "publish"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}